  create view "warehouse"."main"."int_valid_order_items__dbt_tmp" as (
    with order_items as (
    select * from "warehouse"."main"."stg_order_items"
),

orders as (
    select * from "warehouse"."main"."stg_orders"
),

valid_orders as (
