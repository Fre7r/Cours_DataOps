[0m15:02:44.444688 [debug] [Thread-1 (]: On model.dbt_project.customer_revenue: /* {"app": "dbt", "dbt_version": "1.11.11", "profile_name": "dbt_project", "target_name": "dev", "node_id": "model.dbt_project.customer_revenue"} */

  
    
    

    create  table
      "warehouse"."main"."customer_revenue__dbt_tmp"
  
    as (
      with order_items as (
    select * from "warehouse"."main"."stg_order_items"
),

orders as (
    select * from "warehouse"."main"."stg_orders"
),

customers as (
    select * from "warehouse"."main"."stg_customers"
),

-- chiffre d'affaires par ligne de commande
-- cast nécessaire car le flow Prefect a tout converti en string
line_revenue as (
    select
        order_id,
        cast(quantity as integer) * cast(unit_price as double) as revenue
    from order_items
),

-- agrégation par client via la commande
revenue_per_customer as (
    select
        o.customer_id,
        count(distinct o.order_id) as nb_orders,
        sum(lr.revenue)            as total_revenue
    from line_revenue lr
    join orders o on lr.order_id = o.order_id
    group by o.customer_id
)

select
    c.customer_id,
    c.country,
    c.segment,
    rpc.nb_orders,
    round(rpc.total_revenue, 2) as total_revenue
from revenue_per_customer rpc
join customers c on rpc.customer_id = c.customer_id
order by total_revenue desc
    );
  
  
