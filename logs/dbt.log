    where status != 'cancelled'
)

select
    oi.item_id,
    oi.order_id,
    oi.product_id,
    o.customer_id,
    cast(oi.quantity as integer)                                  as quantity,
    cast(oi.quantity as integer) * cast(oi.unit_price as double)  as revenue
from order_items oi
join valid_orders o on oi.order_id = o.order_id
  );

